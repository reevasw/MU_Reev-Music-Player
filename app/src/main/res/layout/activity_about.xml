<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AboutActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Ikon Aplikasi -->
        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:contentDescription="@string/app_name"
            app:shapeAppearanceOverlay="@style/curved"
            android:src="@mipmap/music_player_icon_round" />

        <!-- Nama Aplikasi -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/app_name"
            android:textColor="?colorOnPrimary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Versi Aplikasi -->
        <TextView
            android:id="@+id/aboutVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/abu"
            android:textSize="14sp"
            tools:text="Versi 1.0.0" />

        <!-- Kartu Informasi Pengembang -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/aboutDev"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/artist_icon"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:textColor="?colorOnPrimary"
                    android:textSize="16sp"
                    tools:text="Developer: Arif Septiawardi" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="12dp"
                    android:background="?android:attr/listDivider" />

                <TextView
                    android:id="@+id/aboutProject"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/info_icon"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:textColor="?colorOnPrimary"
                    android:textSize="16sp"
                    tools:text="TA Proyek Integrasi Sistem" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Footer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="Copyright © 2025 MU Reev"
            android:textColor="@color/abu"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
