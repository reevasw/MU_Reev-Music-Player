<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="8dp"
    android:paddingStart="16dp"
    android:paddingEnd="8dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/albumCover"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@mipmap/music_player_icon"
        app:shapeAppearanceOverlay="@style/curved"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true" />

    <ImageView
        android:id="@+id/dragHandle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/drag_indicator_icon"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:alpha="0.7"
        app:tint="@color/white"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_centerVertical="true"
        android:layout_toEndOf="@id/albumCover"
        android:layout_toStartOf="@id/dragHandle"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/queueItemTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Judul Lagu"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:singleLine="true"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/queueItemArtist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Artis"
            android:textColor="@color/abu"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end"/>
    </LinearLayout>
</RelativeLayout>